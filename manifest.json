{
  "manifest_version": 3,
  "name": "GA: Re-run with Inputs",
  "version": "1.0.0",
  "description": "Re-run GitHub Actions workflows and modify the inputs before triggering a new run.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*",
    "https://*.actions.githubusercontent.com/*",
    "https://*.blob.core.windows.net/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/actions/runs/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GA: Re-run with Inputs",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
